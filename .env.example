# 用途：应用名称（展示与服务标识）
APP_NAME=WhereIsIt

# 用途：运行环境标识（如 production / development）
APP_ENV=production

# 用途：JWT 签名密钥，必须在生产环境修改为高强度随机值
SECRET_KEY=please-change-me

# 用途：登录令牌有效期，单位为分钟（10080=7天）
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 用途：允许跨域访问的来源，多个用逗号分隔，内网可用 *，公网建议精确域名
CORS_ORIGINS=*


# 用途：PostgreSQL 数据库名称
POSTGRES_DB=whereisit

# 用途：PostgreSQL 连接用户名
POSTGRES_USER=whereisit

# 用途：PostgreSQL 连接密码
POSTGRES_PASSWORD=please-change-me


# 用途：应用内上传文件保存目录（容器内路径）
UPLOAD_DIR=/data/uploads

# 用途：单张上传图片大小上限，单位 MB
MAX_UPLOAD_MB=10

# 用途：每个物品可上传的最大图片数量
MAX_IMAGES_PER_ITEM=9


# 用途：初始化默认管理员账号（首次创建管理员时使用）
DEFAULT_ADMIN_USERNAME=admin

# 用途：初始化默认管理员密码（可配合 SYNC_DEFAULT_ADMIN_PASSWORD 控制是否每次重置）
DEFAULT_ADMIN_PASSWORD=please-change-me

# 用途：初始化默认管理员显示昵称
DEFAULT_ADMIN_NICKNAME=???

# 用途：是否在每次服务启动时同步重置默认管理员密码（true/false）
SYNC_DEFAULT_ADMIN_PASSWORD=false


# 用途：宿主机映射端口（访问地址为 http://服务器IP:WEB_PORT）
WEB_PORT=3000


# 用途：可选，登录态 Cookie 名称（未配置时使用代码默认值 whereisit_token）
# AUTH_COOKIE_NAME=whereisit_token

# 用途：可选，是否仅在 HTTPS 下发送 Cookie（未配置时默认 false）
# AUTH_COOKIE_SECURE=false

# 用途：可选，是否启用 mDNS 服务发现广播（未配置时默认 true）
# SERVICE_DISCOVERY_ENABLED=true


# 用途：PostgreSQL 服务镜像（可切换主版本，如 14/15/16/17/19）
# 注意：修改 PG_IMAGE 后需重建 app 镜像（docker compose up -d --build），
# Dockerfile 会按此镜像主版本安装对应 postgresql-client。
PG_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine

# 用途：数据库备份恢复执行模式
# 可选：auto（按顺序自动选择 docker_exec -> docker_run_tools -> local）
#      docker_exec（在数据库容器内执行 pg_dump/pg_restore/psql）
#      docker_run_tools（按数据库主版本临时拉起工具容器执行）
#      local（使用应用容器内本地工具，仅主版本匹配时可用）
PG_EXEC_MODE=auto

# 用途：PostgreSQL 容器名（docker_exec 与 docker_run_tools 模式会用到）
PG_CONTAINER_NAME=whereisit-postgres

# 用途：PostgreSQL 在 compose 中的服务名（用于按服务标签回查容器名）
PG_SERVICE_NAME=db

# 用途：工具镜像主模板（{major} 会替换为运行时探测到的数据库主版本）
PG_TOOLS_IMAGE_TEMPLATE=postgres:{major}-alpine

# 用途：工具镜像回退模板（主模板 tag 不存在时自动尝试）
PG_TOOLS_IMAGE_FALLBACK_TEMPLATE=postgres:{major}

# 用途：当前“已验证最大主版本”，高于该值只告警不阻断执行
PG_TESTED_MAX_MAJOR=17

# 用途：服务对外通告主机地址（mDNS/前端提示等场景使用）
SERVICE_ADVERTISE_HOST=127.0.0.1

# 用途：是否启用服务端语音搜索接口（HTTP + WebSocket）
VOICE_SEARCH_ENABLED=true

# 用途：联调开关，true 时最终识别接口直接走 mock 文本
VOICE_SEARCH_MOCK_FINAL=false

# 用途：联调开关，true 时实时流式字幕接口返回 mock partial 文本
VOICE_SEARCH_MOCK_STREAM=false
VOICE_TERMS_INDEX_DELAY_SECONDS=300
VOICE_TERMS_INDEX_POLL_SECONDS=30
VOICE_TERMS_INDEX_BATCH_SIZE=50

# 用途：Android 语音流采样率，当前约定 16k 单声道 PCM
VOICE_STREAM_SAMPLE_RATE=16000
VOICE_STREAM_CHANNELS=1
VOICE_STREAM_MAX_SECONDS=15
VOICE_STREAM_PARTIAL_INTERVAL_MS=150

# 用途：语音会话在服务端内存中的保留时间（秒）
VOICE_SESSION_TTL_SECONDS=300

# 用途：语音识别引擎；当前实现支持 faster_whisper / mock 降级
VOICE_ASR_ENGINE=funasr
VOICE_STREAM_ENGINE=sherpa_onnx
VOICE_OFFLINE_ENGINE=funasr

# 用途：实时回显与最终识别的模型规格，可按服务器性能调大或调小
VOICE_STREAM_MODEL_SIZE=tiny
VOICE_OFFLINE_MODEL_SIZE=tiny
VOICE_MODEL_DEVICE=cpu
VOICE_MODEL_COMPUTE_TYPE=int8
VOICE_MODEL_NUM_THREADS=2
VOICE_MODEL_DOWNLOAD_ROOT=/data/voice-models
VOICE_CLEANING_LEXICON_DIR=/data/voice-cleaning-lexicon
VOICE_SHERPA_PROVIDER=cpu
VOICE_SHERPA_HF_REPO=csukuangfj/sherpa-onnx-streaming-paraformer-bilingual-zh-en
VOICE_SHERPA_MODEL_URL=https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-streaming-paraformer-bilingual-zh-en.tar.bz2
VOICE_SHERPA_MODEL_DIR=/data/voice-models/sherpa-onnx/your-model-dir
VOICE_SHERPA_TOKENS_FILE=tokens.txt
VOICE_SHERPA_ENCODER_FILE=encoder.int8.onnx
VOICE_SHERPA_DECODER_FILE=decoder.int8.onnx
VOICE_FUNASR_MODEL=paraformer-zh
VOICE_FUNASR_VAD_MODEL=fsmn-vad
VOICE_FUNASR_PUNC_MODEL=
VOICE_FUNASR_HUB=ms
